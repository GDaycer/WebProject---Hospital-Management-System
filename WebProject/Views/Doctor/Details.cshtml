@model WebProject.Models.Doctor

@{
    ViewBag.Title = "Details";
}

<h2>Details</h2>

<div>
    <h4>Doctor</h4>
    <hr />
    <dl class="dl-horizontal">
        <dt>Name</dt>
        <dd>@Html.DisplayFor(model => model.User.FirstName) @Html.DisplayFor(model => model.User.LastName)</dd>

        <dt>@Html.DisplayNameFor(model => model.User.Email)</dt>
        <dd>@Html.DisplayFor(model => model.User.Email)</dd>

        <dt>@Html.DisplayNameFor(model => model.Specialty)</dt>
        <dd>@Html.DisplayFor(model => model.Specialty)</dd>

        <dt>@Html.DisplayNameFor(model => model.LicenseNumber)</dt>
        <dd>@Html.DisplayFor(model => model.LicenseNumber)</dd>

        <dt>@Html.DisplayNameFor(model => model.ShiftStart)</dt>
        <dd>@Html.DisplayFor(model => model.ShiftStart)</dd>

        <dt>@Html.DisplayNameFor(model => model.ShiftEnd)</dt>
        <dd>@Html.DisplayFor(model => model.ShiftEnd)</dd>

        <dt>@Html.DisplayNameFor(model => model.Bio)</dt>
        <dd>@Html.DisplayFor(model => model.Bio)</dd>
    </dl>
</div>
<p>
    @Html.ActionLink("Edit", "Edit", new { id = Model.DoctorId }) |
    @Html.ActionLink("Back to List", "List")
</p>