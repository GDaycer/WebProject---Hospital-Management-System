@model IEnumerable<WebProject.Models.Patient>

@{
    ViewBag.Title = "My Patients";
}

@section Styles {
    <link rel="stylesheet" href="@Url.Content("~/Content/DoctorHomePage.css")" />
    <link rel="stylesheet" href="@Url.Content("~/Content/MyPatients.css")" />
}

<main class="doctor_main">
    <div class="dashboard_container">

        <nav class="sidebar_nav_left">
            <h3>Doctor Menu</h3>
            <ul>
                <li><a href="@Url.Action("HomeScreen", "Doctor")">Dashboard</a></li>
                <li><a href="@Url.Action("Schedule", "Doctor")">Full Schedule</a></li>
                <li><a href="@Url.Action("MyPatients", "Doctor")" style="background-color: #007bff; color: white;">My Patient List</a></li>
                <li><a href="@Url.Action("CreateRecord", "Doctor")">Create Record</a></li>
                <li><a href="@Url.Action("DoctorProfile", "Doctor")">Profile</a></li>
            </ul>
        </nav>

        <div class="main_content">
            <h3>My Patient List</h3>


            @if (Model == null || Model.Count() == 0)
            {
                <div class="no_patient">
                    <h4>No Patients Found</h4>
                    <p>You haven't had any appointments with patients yet.</p>
                </div>
            }
            else
            {
                <div class="row">
                    @foreach (var patient in Model)
                    {
                        <div class="appointment_card" style="display: flex; justify-content: space-between; align-items: center; border-left-color: #17a2b8;">

                            <div style="display: flex; align-items: center; gap: 15px;">
                                

                                <div>
                                    <h4>
                                        @if (patient.User != null)
                                        {
                                            @(patient.User.FirstName + " " + patient.User.LastName)
                                        }
                                        else
                                        {
                                            <span>Unknown</span>
                                        }
                                    </h4>

                                    <div style="font-size: 13px; color: #666; margin-top: 4px;">
                                        <span style="margin: 0 5px;">•</span>
                                        <span>Blood: <strong>@(patient.BloodType ?? "--")</strong></span>
                                        <span style="margin: 0 5px;">•</span>
                                        <span>@(patient.Gender ?? "Unknown")</span>
                                    </div>
                                </div>
                            </div>

                            <div>
                                <a href="@Url.Action("PatientHistory", "Doctor", new { id = patient.PatientId })"
                                   class="btn btn-outline-primary"
                                   style="font-size: 13px; border: 1px solid #007bff; color: #007bff; padding: 5px 15px; border-radius: 20px; text-decoration: none; transition: 0.2s;">
                                    Medical History
                                </a>
                            </div>

                        </div>
                    }
                </div>
            }
        </div>

        <div class="doctor_info_card">
            <h4>Directory Stats</h4>
            <hr />
            <div style="text-align:left; padding: 10px;">
                <p><strong>Total Unique Patients:</strong> @Model.Count()</p>
                
            </div>
        </div>

    </div>
</main>