@model WebProject.Models.PatientSignUp

@{
    ViewBag.Title = "Patient Registration";
}
@section Styles {
    <link rel="stylesheet" href="@Url.Content("~/Content/register.css")" />
}

<section class="register_form-container">
    <div class="TheContainer">

        <h2 style="color:#CF352E;">Create Your Patient Account</h2>

        @using (Html.BeginForm("Register", "Patient", FormMethod.Post, new { role = "form" }))
        {
            @Html.AntiForgeryToken()

            <div class="registerRow">

                <div class="registerColumn">
                    <h4>Account Credentials</h4>
                    <hr />
                    <table style="width: 100%;">
                        <tr>
                            <td>@Html.LabelFor(m => m.FirstName)</td>
                            <td>@Html.TextBoxFor(m => m.FirstName, new { @class = "form_control form-control-full" })</td>
                        </tr>

                        <tr>
                            <td>@Html.LabelFor(m => m.LastName)</td>
                            <td>@Html.TextBoxFor(m => m.LastName, new { @class = "form_control form-control-full" })</td>
                        </tr>

                        <tr>
                            <td>@Html.LabelFor(m => m.Email)</td>
                            <td>@Html.TextBoxFor(m => m.Email, new { @class = "form_control form-control-full", @type = "email" })</td>
                        </tr>

                        <tr>
                            <td>@Html.LabelFor(m => m.Password)</td>
                            <td>@Html.PasswordFor(m => m.Password, new { @class = "form_control form-control-full" })</td>
                        </tr>

                        <tr>
                            <td>@Html.LabelFor(m => m.ConfirmPassword)</td>
                            <td>@Html.PasswordFor(m => m.ConfirmPassword, new { @class = "form_control form-control-full" })</td>
                        </tr>

                    </table>
                </div>

                <div class="registerColumn">
                    <h4>Personal & Medical Information <b>(Optional)</b></h4>
                    <hr />
                    <table style="width: 100%;">
                        <tr>
                            <td>@Html.LabelFor(m => m.Gender)</td>
                            <td>
                                @Html.DropDownListFor(m => m.Gender, new List<SelectListItem>
                                {
                                    new SelectListItem { Text = "Male", Value = "Male" },
                                    new SelectListItem { Text = "Female", Value = "Female" },
                                    new SelectListItem { Text = "Other", Value = "Other" }
                                }, "", new { @class = "form_control form-control-full" })
                            </td>
                        </tr>
                        <tr>
                            <td></td>
                            <td>@Html.ValidationMessageFor(m => m.Gender, "", new { @class = "text-danger" })</td>
                        </tr>

                        <tr>
                            <td>@Html.LabelFor(m => m.Address)</td>
                            <td>@Html.TextBoxFor(m => m.Address, new { @class = "form_control form-control-full" })</td>
                        </tr>
                        <tr>
                            <td>@Html.LabelFor(m => m.PhoneNumber)</td>
                            <td>@Html.TextBoxFor(m => m.PhoneNumber, new { @class = "form_control form-control-full", @type = "tel", placeholder = "Ex: 0535 555 55 " })</td>
                        </tr>
                        <tr>
                            <td></td>
                            <td>@Html.ValidationMessageFor(m => m.PhoneNumber, "", new { @class = "text-danger" })</td>
                        </tr>

                        <tr>
                            <td>@Html.LabelFor(m => m.BloodType)</td>
                            <td>
                                @Html.DropDownListFor(m => m.BloodType, new List<SelectListItem>
                                {
                                    new SelectListItem { Text = "A Rh+", Value = "A+" },
                                    new SelectListItem { Text = "A Rh-", Value = "A-" },
                                    new SelectListItem { Text = "B Rh+", Value = "B+" },
                                    new SelectListItem { Text = "B Rh-", Value = "B-" },
                                    new SelectListItem { Text = "0 Rh+", Value = "O+" },
                                    new SelectListItem { Text = "0 Rh-", Value = "O-" },
                                    new SelectListItem { Text = "AB Rh+", Value = "AB+" },
                                    new SelectListItem { Text = "AB Rh-", Value = "AB-" }
                                }, "", new { @class = "form_control form-control-full" })
                            </td>
                        </tr>

                        <tr>
                            <td>@Html.LabelFor(m => m.Height)</td>
                            <td>
                                @Html.TextBoxFor(m => m.Height, new { @class = "form_control form-control-full", @type = "number", placeholder = "cm" })
                            </td>
                        </tr>

                        <tr>
                            <td></td>
                            <td>@Html.ValidationMessageFor(m => m.Height, "", new { @class = "text-danger" })</td>
                        </tr>

                        <tr>
                            <td>@Html.LabelFor(m => m.Weight)</td>
                            <td>
                                @Html.TextBoxFor(m => m.Weight, new { @class = "form_control form-control-full", @type = "number", placeholder = "kg" })
                            </td>
                        </tr>
                        <tr>
                            <td></td>
                            <td>@Html.ValidationMessageFor(m => m.Weight, "", new { @class = "text-danger" })</td>
                        </tr>

                        <tr>
                            <td>@Html.LabelFor(m => m.EmergencyContactName)</td>
                            <td>@Html.TextBoxFor(m => m.EmergencyContactName, new { @class = "form_control form-control-full" })</td>
                        </tr>
                        <tr>
                            <td>@Html.LabelFor(m => m.EmergencyContactNumber)</td>
                            <td>@Html.TextBoxFor(m => m.EmergencyContactNumber, new { @class = "form_control form-control-full", @type = "tel" })</td>
                        </tr>
                    </table>
                </div>
            </div>
            <div class="registerButtonArea">
                <button type="submit" class="registerButton">Register Account</button>
            </div>
        }
    </div>
</section>