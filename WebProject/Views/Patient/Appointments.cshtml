@model WebProject.Models.PatientAppointment

@{
    ViewBag.Title = "My Appointments";
    DateTime? lastDate = null; //helper for grouping dates
}

@section Styles {
    <link rel="stylesheet" href="@Url.Content("~/Content/PatientHomePage.css")" />
    <link rel="stylesheet" href="@Url.Content("~/Content/PatientAppointments.css")" />
}

<main class="patient_main">
    <div class="dashboard_container">

        <nav class="sidebar_nav_left">
            <h3>Patient Menu</h3>

            <ul>
                <li><a href="@Url.Action("Home","Patient")">Dashboard</a></li>
                <li><a href="@Url.Action("Records", "Patient")">My Medical Records</a></li>
                <li><a href="@Url.Action("Appointments", "Patient")" style="background-color: #CF352E; color: white;">My Appointments</a></li>
                <li><a href="@Url.Action("Profile", "Patient")">My Profile</a></li>
                <li><a href="@Url.Action("Book", "Patient")">Book New Appointment</a></li>
            </ul>
        </nav>

        <div class="main_content">
            <h3>My Appointment History</h3>
            <hr />

            @if (Model.AppointmentList == null || Model.AppointmentList.Count == 0)
            {
                <div class="no_history_area">
                    <div class="no_history"></div>
                    <h4>No history found</h4>
                    <p>You haven't booked any appointments yet.</p>
                    <a href="@Url.Action("Book", "Appointment")" class="mini_nav_button">Book Now</a>
                </div>
            }
            else
            {
                <div class="schedule_timeline">
                    @foreach (var item in Model.AppointmentList)
                    {

                        if (lastDate == null || item.startTime.Date != lastDate.Value.Date)
                        {
                            <div class="date_header">
                                @item.startTime.ToString("dddd, MMMM dd, yyyy")
                            </div>
                            lastDate = item.startTime;
                        }


                        <div class="appointment_card">

                            <div class="appointment_card_doctor_name">
                                <div>
                                    <span class="start_time">
                                        @item.startTime.ToString("HH:mm")
                                    </span>
                                    <span class="separator">|</span>
                                    <span class="doctor_name">
                                        @if (item.Doctor != null)
                                        {
                                            <span>Dr. @(item.Doctor.FirstName + " " + item.Doctor.LastName)</span>
                                        }
                                        else
                                        { <span>Unknown Doctor</span>}
                                    </span>
                                </div>

                                <div>
                                    @if (item.status == "Cancelled")
                                    {
                                        <span class="appointment_cancelled">Cancelled</span>
                                    }
                                    else if (item.startTime < DateTime.Now)
                                    {
                                        <span class="appointment_completed">Completed</span>
                                    }
                                    else
                                    {
                                        <span class="appointment_upcoming">Upcoming</span>
                                    }
                                </div>
                            </div>

                            <div class="description">

                                <span class="reason_background">Reason: <strong>@item.ReasonForVisit</strong></span>

                                @if (item.status != "Cancelled" && item.startTime > DateTime.Now)
                                {
                                    using (Html.BeginForm("CancelAppointment", "Patient", new { id = item.appointmentId }, FormMethod.Post))
                                    {
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn-cancel" onclick="return confirm('Cancel this appointment?');">Cancel Appointment</button>
                                    }
                                }
                            </div>

                        </div>
                    }
                </div>
            }
        </div>

        <div class="patient_info_card">
            <div class="patient_header">
                <div class="emoji">📊</div>
                <h4>Overview</h4>
                <span>@Model.FullName</span>
            </div>

            <div class="patient_stats" style="flex-direction: column; gap: 20px;">

                <div class="patient_stats_area">
                    <span style="color: #CF352E; font-size: 12px; font-weight: bold; text-transform: uppercase;">Next Visit</span>
                    @if (Model.NextAppointmentDate.HasValue)
                    {
                        var daysLeft = (Model.NextAppointmentDate.Value - DateTime.Now).Days;

                        <strong style="font-size: 1.4rem; color: #333; display: block; margin-top: 5px;">
                            @(daysLeft == 0 ? "TODAY" : daysLeft + " Days")
                        </strong>

                        <span style="font-size: 0.9rem; color: #777;">@Model.NextAppointmentDate.Value.ToString("MMM dd • HH:mm")</span>
                    }
                    else
                    {
                        <strong class="no_visit_sign">--</strong>
                        <span class="no_visits">No upcoming visits</span>
                    }
                </div>

                <div class="stat_horizontal_separator">
                    <div style="text-align: center; flex: 1;">
                        <span class="done">Done</span>
                        <strong class="done_text">@Model.TotalCompleted</strong>
                    </div>
                    <div class="stat_vertical_separator">
                        <span class="cancelled">Cancelled</span>
                        <strong class="cancelled_text">@Model.TotalCancelled</strong>
                    </div>
                </div>

            </div>
        </div>

    </div>
</main>