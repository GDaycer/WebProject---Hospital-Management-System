@model WebProject.Models.BookAppointment

@{
    ViewBag.Title = "Book Appointment";
}

@section Styles {
    <link rel="stylesheet" href="@Url.Content("~/Content/PatientHomePage.css")" />
    <link rel="stylesheet" href="@Url.Content("~/Content/PatientBooking.css")" />
}

<main class="patient_main">
    <div class="dashboard_container">

        <nav class="sidebar_nav_left">
            <h3>Patient Menu</h3>
            <ul>
                <li><a href="@Url.Action("Home","Patient")">Dashboard</a></li>
                <li><a href="@Url.Action("Records", "Patient")">My Medical Records</a></li>
                <li><a href="@Url.Action("Appointments", "Patient")">My Appointments</a></li>
                <li><a href="@Url.Action("Profile", "Patient")">My Profile</a></li>
                <li><a href="@Url.Action("Book", "Patient")" style="background-color: #CF352E; color: white;">Book New Appointment</a></li>
            </ul>
        </nav>

        <div class="main_content">
            <h3>Book a New Appointment</h3>
            <hr />

            @using (Html.BeginForm())
            {
                @Html.AntiForgeryToken()

                if (!ViewData.ModelState.IsValid)
                {
                    <div class="validation_message">
                        @Html.ValidationSummary(false, "Please fix the following errors:")
                    </div>
                }

                <div class="form_area">

                    <label class="input_label">Select Doctor</label>
                    @Html.DropDownListFor(m => m.DoctorId, Model.DoctorsList, "Choose a Specialist", new { @class = "form_box" })

                </div>


                <div class="two_col_row">

                    <div class="form_area" style="flex:1;">

                        <label class="input_label">Date</label>
                        @Html.EditorFor(m => m.Date, new { htmlAttributes = new { @class = "form_box", type = "date" } })

                    </div>


                    <div class="form_area" style="flex:1;">

                        <label class="input_label">Time</label>
                        @Html.EditorFor(m => m.Time, new { htmlAttributes = new { @class = "form_box", type = "time" } })

                    </div>


                </div>


                <div class="form_area">

                    <label class="input_label">Reason for Visit</label>
                    @Html.TextAreaFor(m => m.Reason, new { @class = "form_box", rows = "3", placeholder = "Describe your symptoms (e.g. Headache, Fever etc.)" })

                </div>

                <button type="submit" class="book_btn">Confirm Appointment</button>
            }
        </div>

        <div class="patient_info_card">
            <div class="patient_header">
                <div class="tip_area"></div>
                <h4>Booking Tips</h4>
            </div>
            <div class="tips">

                <p>Doctor may not be always available for your desired time period.</p>
                <hr />
                <p>Please be specific about the reason of your visit.</p>
                
            </div>
        </div>

    </div>
</main>